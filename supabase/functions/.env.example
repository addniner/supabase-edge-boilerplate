# =============================================================================
# Edge Functions 환경 변수
# =============================================================================
# [필수] 표시가 없으면 해당 기능 사용 시에만 필요합니다.
# =============================================================================


# -----------------------------------------------------------------------------
# 기본 설정
# -----------------------------------------------------------------------------

# 환경 구분 (local | staging | production)
ENVIRONMENT="local"

# ngrok URL (로컬에서 외부 접근 필요 시 - AI 이미지 전달, 웹훅 테스트 등)
NGROK_URL=""


# -----------------------------------------------------------------------------
# 데이터베이스 [필수]
# -----------------------------------------------------------------------------

# PostgreSQL 연결 URL
# 로컬: postgresql://postgres:postgres@host.docker.internal:54322/postgres
# 원격: Supabase Dashboard > Settings > Database > Connection string
DB_URL=""

# SSL 인증서 (원격 DB 연결 시 필요, 로컬은 비워둠)
DB_SSL_CERT=""


# -----------------------------------------------------------------------------
# 웹훅 인증 [필수]
# -----------------------------------------------------------------------------

# DB 트리거에서 Edge Function 호출 시 사용하는 시크릿
# 00_vault.sql의 webhook_secret과 동일한 값으로 설정
DB_WEBHOOK_SECRET=""


# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Storage 버킷 설정 [필수]
# 예시: '{"PROJECTS_BUCKET":"projects","ASSETS_BUCKET":"assets","PUBLIC_RESOURCES_BUCKET":"public-resources"}'
STORAGE_CONFIG_JSON='{}'


# -----------------------------------------------------------------------------
# Supabase Storage AWS S3
# -----------------------------------------------------------------------------

# S3 액세스 키
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

