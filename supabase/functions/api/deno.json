{
  "lock": false,
  "compilerOptions": {
    "types": ["./edge-runtime.d.ts"]
  },
  "lint": {
    "rules": {
      "include": [
        "no-console",
        "no-throw-literal",
        "no-var",
        "prefer-const",
        "no-unreachable",
        "no-explicit-any"
      ]
    }
  },
  "fmt": {
    "exclude": ["**/supabase.types.ts"]
  },
  "imports": {
    "@middleware": "./presentation/middleware/index.ts",
    "@config": "./infrastructure/config/index.ts",

    "@domain": "./domain/value-objects/index.ts",
    "@domain/exceptions": "./domain/exceptions/index.ts",
    "@domain/gateways": "./domain/gateways/index.ts",
    "@domain/repositories": "./domain/repositories/index.ts",

    "@logger": "./infrastructure/logger/index.ts",

    "@clients": "./infrastructure/clients/index.ts",
    "@adapters": "./infrastructure/adapters/index.ts",
    "@factories": "./infrastructure/factories/index.ts",
    "@repositories": "./infrastructure/repositories/index.ts",
    "@db": "./infrastructure/db/index.ts",
    "@infrastructure/utils": "./infrastructure/utils/index.ts",

    "@routes": "./presentation/routes/index.ts",

    "@usecases/_example": "./application/usecases/_example/index.ts",

    "@openapi": "./presentation/utils/openapi.ts",
    "@test/env": "./__tests__/env.ts",

    "@edge-runtime": "jsr:@supabase/functions-js/edge-runtime.d.ts",
    "@supabase-js": "jsr:@supabase/supabase-js@2",

    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/testing/bdd": "jsr:@std/testing@^1/bdd",

    "@hono": "npm:hono@~4.7.0",
    "@hono/combine": "npm:hono@~4.7.0/combine",
    "@hono/language": "npm:hono@~4.7.0/language",
    "@hono/http-status": "npm:hono@~4.7.0/utils/http-status",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@~0.18.0",
    "@hono/swagger-ui": "npm:@hono/swagger-ui@~0.5.0",
    "@zod": "npm:zod@~3.23.0",

    "@drizzle-orm": "npm:drizzle-orm@1.0.0-beta.9-e89174b",
    "@drizzle-orm/pg-core": "npm:drizzle-orm@1.0.0-beta.9-e89174b/pg-core",
    "@drizzle-orm/postgres-js": "npm:drizzle-orm@1.0.0-beta.9-e89174b/postgres-js",
    "@drizzle-orm/supabase": "npm:drizzle-orm@1.0.0-beta.9-e89174b/supabase",
    "@postgres-js": "npm:postgres@3.4.5",
    "@sql-formatter": "npm:sql-formatter@~15.0.0",
    "@std/fmt": "jsr:@std/fmt@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",

    "@p-limit": "npm:p-limit@~7.2.0",
    "@async-retry": "npm:async-retry@~1.3.3",
    "@fractional-indexing": "npm:fractional-indexing@~3.2.0",
    "@image-size": "npm:image-size@~2.0.2"
  }
}
