# =============================================================================
# Supabase 로컬 환경 설정
# =============================================================================
# 이 파일은 Supabase CLI가 사용하는 환경 변수입니다.
# Google OAuth 로그인 테스트 시에만 필요합니다.
#
# 설정 방법:
# 1. Google Cloud Console (https://console.cloud.google.com) 접속
# 2. APIs & Services > Credentials > OAuth 2.0 Client IDs 생성
# 3. Authorized redirect URIs에 http://127.0.0.1:54321/auth/v1/callback 추가
# =============================================================================

# Google OAuth 클라이언트 ID
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=""

# Google OAuth 클라이언트 시크릿
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=""

SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=""
