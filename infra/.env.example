# =============================================
# 공통 설정 (infra/.env)
# =============================================

# Supabase Management API
# 발급: https://supabase.com/dashboard/account/tokens
TF_VAR_supabase_access_token=sbp_xxxxxxxxxxxxxxxxxxxx

# Supabase Organization ID
# 확인: https://supabase.com/dashboard/org/_/settings
TF_VAR_organization_id=xxxxxxxxxxxxxxxxxxxx

# Terraform Cloud API Token (State 원격 관리)
# 발급: https://app.terraform.io/app/settings/tokens
TF_API_TOKEN=your_terraform_cloud_api_token
