# =============================================
# 공통 설정 → infra/.env
# =============================================

# Supabase Management API
# 발급: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxx

# Supabase Organization ID
# 확인: https://supabase.com/dashboard/org/_/settings
ORGANIZATION_ID=xxxxxxxxxxxxxxxxxxxx

# Terraform Cloud API Token (State 원격 관리)
# 발급: https://app.terraform.io/app/settings/tokens
TF_API_TOKEN=your_terraform_cloud_api_token

# =============================================
# 환경별 설정 → infra/.env.staging, infra/.env.production
# =============================================

# Terraform이 TF_VAR_* 형식을 자동으로 인식
TF_VAR_database_password=your_password
TF_VAR_site_url=https://your-domain.com

# Google OAuth (Google Cloud Console > API & Services > Credentials)
TF_VAR_external_google_client_id=xxxx.apps.googleusercontent.com
TF_VAR_external_google_secret=GOCSPX-xxxx

# Terraform apply 후 terraform output project_id로 확인
PROJECT_ID=your_project_id
