# =============================================
# 환경 설정 (infra/.env.<staging|production>)
# =============================================


# ========== Terraform Variables ==========

# Supabase Management API 발급: https://supabase.com/dashboard/account/tokens
TF_VAR_supabase_access_token=sbp_xxxxxxxxxxxxxxxxxxxx

# Supabase Organization ID 확인: https://supabase.com/dashboard/org/_/settings
TF_VAR_organization_id=xxxxxxxxxxxxxxxxxxxx

TF_VAR_database_password=your_password

# Google OAuth (Google Cloud Console > API & Services > Credentials)
TF_VAR_external_google_client_id=xxxx.apps.googleusercontent.com
TF_VAR_external_google_secret=GOCSPX-xxxx


# ========== Terraform Cloud ==========

# API Token 발급: https://app.terraform.io/app/settings/tokens
TF_API_TOKEN=your_terraform_cloud_api_token


# ========== Google Chat ==========

# 배포 알림 Webhook URL
GOOGLE_CHAT_WEBHOOK_URL=


# ========== Output ==========

# Supabase Project ID (.scripts/infra-tf.sh {environment} apply 후 자동 기록됨)
SUPABASE_PROJECT_ID=your_project_id
